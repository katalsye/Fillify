<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.Fillify" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary: 세이지 그린 -->
        <item name="colorPrimary">@color/sage</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/sage_container</item>
        <item name="colorOnPrimaryContainer">@color/sage_on_container</item>

        <!-- Secondary: 세이지 컨테이너 톤 -->
        <item name="colorSecondary">@color/sage_on_container</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/sage_container</item>
        <item name="colorOnSecondaryContainer">@color/sage_on_container</item>

        <!-- Tertiary / Accent: 형광 노랑 -->
        <item name="colorTertiary">@color/highlight_deep</item>
        <item name="colorOnTertiary">@color/highlight_on</item>
        <item name="colorTertiaryContainer">@color/highlight</item>
        <item name="colorOnTertiaryContainer">@color/highlight_on</item>

        <!-- Surfaces -->
        <item name="android:colorBackground">@color/surface_light</item>
        <item name="colorOnBackground">@color/on_surface_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_muted_light</item>
        <item name="colorSurfaceContainer">@color/surface_container_light</item>
        <item name="colorSurfaceContainerLow">@color/surface_container_light</item>
        <item name="colorSurfaceContainerHigh">@color/surface_variant_light</item>

        <item name="colorOutline">@color/outline_light</item>
        <item name="colorOutlineVariant">@color/surface_variant_light</item>
        <item name="colorError">@color/error_light</item>

        <item name="android:statusBarColor">@color/surface_light</item>
    </style>

    <style name="Theme.Fillify" parent="Base.Theme.Fillify" />

    <!-- 형광펜 칩(단어 선택)용 텍스트 스타일 -->
    <style name="TextAppearance.Fillify.Chip" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">15sp</item>
    </style>
</resources>
